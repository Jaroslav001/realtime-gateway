# App
PORT=3002
NODE_ENV=development

# Database — same chat_service database
DATABASE_URL="postgresql://sail:password@localhost:5432/chat_service"

# Redis — DB index 1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# JWT — shared secret with Laravel
JWT_SECRET=your-shared-jwt-secret

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3003
